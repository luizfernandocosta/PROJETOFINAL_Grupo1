# =============================================================
# .env.example — copie para .env e ajuste conforme necessário
#
#   cp .env.example .env
#
# NUNCA versione o arquivo .env — ele está no .gitignore.
# =============================================================

# -------------------------------------------------------------
# Docker Compose
# -------------------------------------------------------------
COMPOSE_PROJECT_NAME=inmet_weather_stack

# -------------------------------------------------------------
# PostgreSQL — banco de dados principal
# -------------------------------------------------------------
POSTGRES_USER=inmet_user
POSTGRES_PASSWORD=inmet_pass
POSTGRES_DB=inmet_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -------------------------------------------------------------
# Usuário de analytics (dbt + Metabase)
# Criado em sql/init/00_create_databases.sql
# -------------------------------------------------------------
ANALYTICS_USER=analytics_user
ANALYTICS_PASSWORD=analytics_pass

# -------------------------------------------------------------
# Airflow — banco de metadados separado do banco principal
# -------------------------------------------------------------
AIRFLOW_DB=airflow_db
AIRFLOW_DB_USER=airflow_user
AIRFLOW_DB_PASSWORD=airflow_pass
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_UID=50000

# -------------------------------------------------------------
# Metabase — banco de metadados externalizado (evita perda de dashboards)
# -------------------------------------------------------------
METABASE_DB=metabase_db
METABASE_DB_USER=analytics_user
METABASE_DB_PASSWORD=analytics_pass

# -------------------------------------------------------------
# Portas locais — altere se houver conflito na sua máquina
# Exemplo: se a porta 3000 estiver ocupada, mude METABASE_PORT=3001
# -------------------------------------------------------------
POSTGRES_LOCAL_PORT=5432
AIRFLOW_PORT=8080
DBT_DOCS_PORT=8081
METABASE_PORT=3001

# -------------------------------------------------------------
# Ingestão INMET
# -------------------------------------------------------------
# Anos a ingerir (separados por vírgula, sem espaços)
INMET_YEARS=2024,2025

# URL base dos dados históricos do INMET
INMET_BASE_URL=https://portal.inmet.gov.br/uploads/dadoshistoricos

# Modo de carga: full_refresh (trunca e recarrega) ou incremental (só novos)
LOAD_MODE=full_refresh
